<?xml version="1.0" encoding="UTF-8"?>
<app xmlns="https://sp1rit.arpa/pixiewood/">
        <metainfo>
                <component xmlns="https://specifications.freedesktop.org/metainfo/1.0" type="desktop">
                        <id>de.mfxbe.GiDAndroidApp</id>
                        <name>GiDAndroidApp</name>
                        <releases>
                                <release version="0">
                                        <description>
                                                <p>Initial release</p>
                                        </description>
                                </release>
                        </releases>
                </component>
        </metainfo>
        <style>
                <theme name="gtk"/>
                <icon type="generate">
                        <drawable target="foreground" scale=".45" type="svg" path="src://logo.svg"/>
                        <color target="background">#FFFFFF</color>
                        <drawable target="monochrome" scale=".45" type="svg" path="src://logo.svg"/>
                </icon>
        </style>
        <dependencies>
                <glib>
                        <patch>hack</patch>
                </glib>
                <fontconfig/>
                <gtk/>
        </dependencies>
        <build target="giDAndroidApp">
                <architectures>
                        <arch>aarch64</arch>
                        <arch>x86_64</arch>
                </architectures>
                <configure-options>
                        <option>--cross=crossfile.txt</option>
                </configure-options>
        </build>
</app>
